# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file — it holds your private key.

# Your MetaMask testnet-only account's private key (starts with 0x)
PRIVATE_KEY=

# Ritual Chain testnet RPC
RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# Ritual Chain contract verifier (used by `forge verify-contract`)
RITUAL_VERIFIER_URL=https://rpc.ritualfoundation.org/api/verify
